{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "FastAPI: agent_api.agent_server",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "agent_api.agent_server:app",
                "--reload"
            ],
            "jinja": true,
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "FastAPI: backend_poc.api.main",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "backend_poc.api.main:app",
                "--reload"
            ],
            "jinja": true,
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "FastAPI: speech-to-text",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/microsoft-agents/speech-to-text/server.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/microsoft-agents/speech-to-text"
        }
    ]
}